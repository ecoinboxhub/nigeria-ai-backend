APP_NAME=Nigeria Construction AI Platform
ENV=development
DEBUG=true
API_PREFIX=/api/v1
PRODUCTION_DOMAIN=
API_HOST=127.0.0.1
API_PORT=8000

API_KEY=change-me
JWT_SECRET=change-me-super-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=120
JWT_REFRESH_EXPIRES_MINUTES=10080

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=construction_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/construction_ai

MONGO_URI=mongodb://localhost:27017
MONGO_DB=construction_ai

VECTOR_STORE=chromadb
CHROMA_PATH=./artifacts/chroma
CHROMA_PERSIST_DIR=data/processed/vector_indexes
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_ENV=

# Weather
OPENWEATHER_API_KEY=
WEATHER_API_KEY=
WEATHER_CACHE_TTL=1800
OPENWEATHER_EXCLUDE_PARTS=minutely,alerts

# LLM
OPENAI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
HUGGINGFACEHUB_API_TOKEN=
LLM_DEFAULT_MODEL=gpt-4o-mini
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# Redis
REDIS_URL=redis://localhost:6379/0

# Scraping
SCRAPING_INTERVAL_HOURS=6
JIJI_BASE_URL=https://jiji.ng/building-materials
AROUNDDEAL_API_KEY=
SENSOTO_API_KEY=
DATARADE_API_KEY=

# MLflow
MLFLOW_TRACKING_URI=./artifacts/mlruns
MLFLOW_EXPERIMENT_PREFIX=nigeria_construction
MODEL_REGISTRY_PATH=./artifacts/models

# DVC
DVC_REMOTE_URL=

# Deployment
RENDER_API_KEY=

# Nginx + Ngrok
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# Endpoint validation
API_TEST_PORT=8000
USE_EXISTING_API=false
